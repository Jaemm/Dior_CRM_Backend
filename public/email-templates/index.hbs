<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Email Confirmation</title>
        <style>
            .flex { display: flex; } .grow { flex-grow: 1; } .flex-col { flex-direction: column; } .justify-center {
            justify-content: center; } .gap-4 { gap: 1rem; } .text-center { text-align: center; } .text-2xl { font-size:
            1.5rem; } .font-bold { font-weight: bold; } .max-w-sm { max-width: 24rem; } .rounded-md { border-radius:
            0.375rem; } .bg-white { background-color: #ffffff; } .p-4 { padding: 1rem; } .shadow-lg { box-shadow: 0 10px
            15px rgba(0, 0, 0, 0.1); } .w-full { width: 100%; }
        </style>
    </head>
    <body>
        <div class="flex grow flex-col justify-center gap-4">
            <h1 class="text-center text-2xl font-bold">
                {{email_confirmation}}
            </h1>

            <div class="flex max-w-sm flex-col gap-4 rounded-md bg-white p-4 text-center shadow-lg">
                <p>
                    {{#if isError}}
                        this confirmation link is expired. Please request a new confirmation Email
                    {{else}}
                        your email has been successfully confirmed.
                    {{/if}}
                </p>
            </div>
        </div>
    </body>
</html>