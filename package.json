{
  "name": "nest-typescript-starter",
  "private": true,
  "version": "1.0.0",
  "description": "Nest TypeScript starter repository",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config jest-e2e.json",
    "typeorm": "ts-node ./node_modules/typeorm/cli",
    "migration:run": "npm run typeorm migration:run -- -d ./src/config/typeOrm.config.ts",
    "migration:generate": "npm run typeorm -- -d ./src/config/typeOrm.config.ts migration:generate ./src/migrations/$npm_config_name",
    "migration:create": "npm run typeorm -- migration:create ./src/migrations/$npm_config_name",
    "migration:revert": "npm run typeorm -- -d ./src/config/typeOrm.config.ts migration:revert",
    "cm": "cz",
    "prepare": "husky"
  },
  "dependencies": {
    "@hapi/joi": "^17.1.1",
    "@nestjs/axios": "^3.0.2",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/devtools-integration": "^0.2.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@types/aws-sdk": "^2.7.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/hapi__joi": "^17.1.8",
    "@types/joi": "^17.2.3",
    "@types/nodemailer": "^6.4.14",
    "@types/serve-static": "^1.15.7",
    "@types/uuid": "^9.0.7",
    "axios": "^1.8.4",
    "bcrypt": "^5.1.1",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.6",
    "cos-nodejs-sdk-v5": "^2.12.1",
    "csv": "^6.3.9",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-session": "^1.18.1",
    "firebase-admin": "^10.3.0",
    "form-data": "^4.0.0",
    "google-auth-library": "^9.11.0",
    "handlebars": "^4.7.8",
    "install": "^0.13.0",
    "ioredis": "^5.3.2",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.3",
    "npm": "^11.0.0",
    "passport": "^0.7.0",
    "passport-saml": "^3.2.4",
    "pg": "^8.8.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.5.5",
    "saml2-js": "^2.0.9",
    "samlify": "^2.10.1",
    "serve-static": "^1.15.0",
    "slugify": "^1.6.6",
    "ssh2-sftp-client": "^11.0.0",
    "swagger": "^0.0.1",
    "typeorm": "^0.3.11",
    "typeorm-model-generator": "^0.4.3",
    "typeorm-naming-strategies": "^4.1.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^7.3.1",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^4.17.13",
    "@types/express-session": "^1.18.1",
    "@types/jest": "^28.1.4",
    "@types/lodash": "^4.17.7",
    "@types/multer": "^1.4.11",
    "@types/node": "^18.0.3",
    "@types/passport-jwt": "^3.0.13",
    "@types/qrcode": "^1.5.5",
    "@types/saml2-js": "^3.0.4",
    "@types/supertest": "^2.0.12",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^5.30.5",
    "@typescript-eslint/parser": "^5.30.5",
    "argon2": "^0.31.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^9.1.7",
    "jest": "^28.1.2",
    "passport-jwt": "^4.0.1",
    "prettier": "^2.7.1",
    "source-map-support": "^0.5.21",
    "supertest": "^6.2.4",
    "ts-jest": "^28.0.5",
    "ts-loader": "^9.3.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^4.7.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
